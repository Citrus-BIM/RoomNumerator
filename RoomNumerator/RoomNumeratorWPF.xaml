<Window x:Class="RoomNumerator.RoomNumeratorWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"

        Title="Нумератор помещений"
        Width="400" Height="320"
        MinWidth="400" MinHeight="320"
        MaxWidth="400" MaxHeight="320"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/RoomNumerator;component/Resources/citrus.ico"
        WindowStartupLocation="CenterScreen"
        KeyDown="RoomNumeratorWPF_KeyDown"

        FontFamily="{DynamicResource BaseFont}"
        FontSize="{DynamicResource FontSizeBase}"
        Foreground="{DynamicResource TextBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Language="ru-RU">

    <!-- Citrus theme -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- замени assembly/путь при необходимости -->
                <ResourceDictionary Source="/RoomNumerator;component/CitrusTheme/CitrusTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== TOP INPUTS ===================== -->
        <Grid Grid.Row="0" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>

            <Label x:Name="label_NumberPrefix"
                   Grid.Column="0"
                   Content="Префикс номера:"
                   VerticalContentAlignment="Center"
                   Margin="0,0,10,0"/>

            <TextBox x:Name="textBox_NumberPrefix"
                     Grid.Column="1"
                     Height="32"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     Padding="0,0,5,0"/>

            <Label x:Name="label_StartFrom"
                   Grid.Column="3"
                   Content="Начинать с:"
                   VerticalContentAlignment="Center"
                   Margin="10,0,10,0"/>

            <TextBox x:Name="textBox_StartFrom"
                     Grid.Column="4"
                     Height="32"
                     Text="1"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     Padding="0,0,5,0"/>
        </Grid>

        <!-- ===================== DIRECTION ===================== -->
        <GroupBox x:Name="groupBox_NumberingDirection"
                  Grid.Row="1"
                  Header="Направление нумерации:"
                  Margin="0,0,0,6">

            <UniformGrid Margin="6,4,6,6"
                         Rows="2"
                         Columns="2">

                <Border Padding="6"
                        Margin="0,0,6,6"
                        CornerRadius="6"
                        BorderThickness="1">
                    <RadioButton x:Name="radioButton_RightAndDown"
                                 GroupName="NumberingDirection"
                                 IsChecked="True"
                                 Padding="0"
                                 Margin="0"
                                 VerticalContentAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Вправо и вниз"/>
                            <TextBlock Text="→ затем ↓"
                                       Opacity="0.65"
                                       FontSize="9"
                                       Margin="0,1,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </Border>

                <Border Padding="6"
                        Margin="6,0,0,6"
                        CornerRadius="6"
                        BorderThickness="1">
                    <RadioButton x:Name="radioButton_DownAndRight"
                                 GroupName="NumberingDirection"
                                 Padding="0"
                                 Margin="0"
                                 VerticalContentAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Вниз и вправо"/>
                            <TextBlock Text="↓ затем →"
                                       Opacity="0.65"
                                       FontSize="9"
                                       Margin="0,1,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </Border>

                <Border Padding="6"
                        Margin="0,6,6,0"
                        CornerRadius="6"
                        BorderThickness="1">
                    <RadioButton x:Name="radioButton_RightAndUp"
                                 GroupName="NumberingDirection"
                                 Padding="0"
                                 Margin="0"
                                 VerticalContentAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Вправо и вверх"/>
                            <TextBlock Text="→ затем ↑"
                                       Opacity="0.65"
                                       FontSize="9"
                                       Margin="0,1,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </Border>

                <Border Padding="6"
                        Margin="6,6,0,0"
                        CornerRadius="6"
                        BorderThickness="1">
                    <RadioButton x:Name="radioButton_UpAndRight"
                                 GroupName="NumberingDirection"
                                 Padding="0"
                                 Margin="0"
                                 VerticalContentAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Вверх и вправо"/>
                            <TextBlock Text="↑ затем →"
                                       Opacity="0.65"
                                       FontSize="9"
                                       Margin="0,1,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </Border>

            </UniformGrid>
        </GroupBox>

        <!-- ===================== BUTTONS ===================== -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="btn_Ok"
                        Content="Ок"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="0,0,5,0"
                        IsDefault="True"
                        Click="btn_Ok_Click"/>

                <Button x:Name="btn_Cancel"
                        Content="Отмена"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="5,0,0,0"
                        IsCancel="True"
                        Style="{StaticResource ButtonOutline}"
                        Click="btn_Cancel_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>